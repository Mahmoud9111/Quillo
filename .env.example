# Public base URL of the deployed app (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_BASE_URL=

# Clerk authentication — get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Vercel Blob — auto-injected by the Vercel integration once a Blob store
# is connected to the project. Set manually only for local dev.
BLOB_READ_WRITE_TOKEN=

# MongoDB Atlas connection string
MONGODB_URI=

# Vapi voice AI — https://vapi.ai
NEXT_PUBLIC_VAPI_API_KEY=
NEXT_PUBLIC_ASSISTANT_ID=
VAPI_SERVER_SECRET=

# Google Gemini API key (used for embeddings)
GOOGLE_GEMINI_API_KEY=

# ElevenLabs API key (used for TTS voices)
ELEVENLABS_API_KEY=
