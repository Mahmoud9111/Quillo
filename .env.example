# ============================================
# Clerk authentication — https://dashboard.clerk.com
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ============================================
# Vercel Blob — auto-injected once a Blob store
# is connected to the Vercel project. Set manually
# only for local dev.
# ============================================
BLOB_READ_WRITE_TOKEN=

# ============================================
# MongoDB Atlas connection string
# ============================================
MONGODB_URI=

# ============================================
# Vapi voice AI — https://vapi.ai
# VAPI_SERVER_SECRET is REQUIRED in production:
# it's checked against the X-Vapi-Secret header
# on the /api/vapi/search-book webhook. Configure
# the same value in the Vapi assistant's Custom
# Headers setting.
# ============================================
NEXT_PUBLIC_VAPI_API_KEY=
NEXT_PUBLIC_ASSISTANT_ID=
VAPI_SERVER_SECRET=
